# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/projexify_db
# Get your MongoDB URI from: https://www.mongodb.com/cloud/atlas

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key

# Server Configuration
PORT=3005
NODE_ENV=development
CORS_ORIGIN=http://localhost:3005
FRONTEND_URL=http://localhost:3005

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./backend/uploads

# Email Configuration (Nodemailer)
# For Gmail: Enable "Less secure app access" or use App Password
# For SendGrid: Use apikey as username and your API key as password
# For Mailtrap: Get credentials from your Mailtrap account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@projexify.io

# Email Service Options: gmail | sendgrid | mailtrap | custom
EMAIL_SERVICE=gmail
EMAIL_VERIFICATION=true

# Content Shield
ENABLE_CONTENT_SHIELD=true
WATERMARK_TEXT=Projexify™

# Application URLs
REGISTER_URL=/register
LOGIN_URL=/login
RESET_PASSWORD_URL=/reset-password

